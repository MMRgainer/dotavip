# Dota Overlay — local configuration
# Copy this file to .env and adjust as needed.

DOTA_MONITOR_INDEX=1          # mss index 1 = 2560x1440 Dota monitor (index 2 = dashboard)
DOTA_RESOLUTION=2560x1440

# Tesseract — adjust if installed to a different path
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

CAPTURE_FPS=4
HOST=127.0.0.1
PORT=8765
LOG_LEVEL=info
